---
import { ClientRouter } from 'astro:transitions';
import { AstroSeo } from '@astrolib/seo';
import '@/styles/global.css';

const title = 'OpenSymbiose - Blog';
const description =
  'Blog o praktyce inspekcji drzew. Bez teorii oderwanej od terenu.';
const siteUrl = 'https://opensymbiose.pl';
const ogImage = `${siteUrl}/og-image.jpg`;
---

<AstroSeo
  title={title}
  description={description}
  canonical={siteUrl}
  openGraph={{
    url: siteUrl,
    title,
    description,
    images: [
      {
        url: ogImage,
        width: 1200,
        height: 630,
        alt: "OpenSymbiose - Blog",
        type: "image/jpeg",
      },
    ],
    site_name: "OpenSymbiose",
    type: "website",
    locale: "pl_PL",
  }}
/>

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<meta name="robots" content="index, follow" />
<meta name="theme-color" content="#ffffff" />

<link rel="icon" href="/favicon.ico" sizes="any" />
<link rel="icon" href="/icon.svg" type="image/svg+xml" />
<link rel="apple-touch-icon" href="/apple-touch-icon.png" />

<link rel="preconnect" href="https://rsms.me" />
<link rel="stylesheet" href="https://rsms.me/inter/inter.css" />
<link rel="stylesheet" href="https://api.fontshare.com/v2/css?f[]=jet-brains-mono@1,2&display=swap" />

<ClientRouter />

<script defer src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js"></script>
