---
import { getCollection } from 'astro:content';
import BlogEntries from '@/components/entries/BlogEntry.astro';
import Cta from '@/components/global/Cta.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';

const allPosts = await getCollection('posts');
const tags = [...new Set(allPosts.flatMap((post) => post.data.tags))];

const sortedPosts = allPosts.sort(
  (a, b) =>
    new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime(),
);
---

<BaseLayout>
  <section>
    <div class="py-24">
      <h1
        class="text-4xl text-balance font-medium font-display text-base-900 max-w-xl"
      >
        Blog o praktyce inspekcji drzew. Bez teorii oderwanej od terenu.
      </h1>
      <div class="flex flex-wrap gap-3 mt-8">
        {
          tags.map((tag) => (
            <a
              class=" hover:text-green-500 text-xs font-medium text-base-600"
              href={`/tags/${tag}`}
            >
              {tag}
            </a>
          ))
        }
      </div>
      <div class="grid grid-cols-1 mt-4 gap-8 gap-y-24 sm:grid-cols-2">
        {
          sortedPosts.map((post) => (
            <BlogEntries
              url={"/posts/" + post.id}
              alt={post.data.title}
              tags={post.data.tags}
              title={post.data.title}
              author={post.data.author}
              image={post.data.image.url}
              description={post.data.description}
              pubDate={post.data.pubDate.toString().slice(0, 10)}
            />
          ))
        }
      </div>
    </div>
  </section>
  <Cta />
</BaseLayout>
